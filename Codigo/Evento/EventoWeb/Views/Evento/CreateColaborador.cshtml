@model EventoWeb.Models.GestaoPapelModel

<link href="~/lib/datatable/css/datatables.min.css" rel="stylesheet" />

<h1 class="blue-normal">Cadastrar Colaboradores do Evento</h1>
<hr />

<div class="row">
	<div>
		<form asp-action="AtribuirPapel" method="post" onsubmit="return validarFormulario()">
			@Html.AntiForgeryToken()
			<input type="hidden" name="idPapelRequisitado" value="3" />

			<div class="row">
				<div class="col-lg-3">
					<div class="form-group">
						<label for="IdEvento" class="control-label">Evento</label>
						<select id="IdEvento" name="IdEvento" class="form-control" readonly>
							@if (Model.Evento == null || Model.Evento.Id == 0)
							{
								<option value="0">Não Informado</option>
							}
							else
							{
								<option value="@Model.Evento.Id" selected>@Model.Evento.Nome</option>
							}
						</select>
						@Html.HiddenFor(model => model.Evento.Id)
						@Html.HiddenFor(model => model.Evento.Nome)
					</div>
				</div>
			</div>
			<br />
			<h4 class="blue-normal">
				Dados do colaborador
			</h4>
			<div class="row">
				<div class="col-6 col-sm-6 col-md-3 col-lg-2">
					<div class="form-group">
						<label asp-for="Pessoa.Cpf" class="control-label">CPF</label>
						<input asp-for="Pessoa.Cpf" class="form-control" id="cpfInput" placeholder="000.000.000-00" onblur="buscarPessoaPorCPF()" />
						<span asp-validation-for="Pessoa.Cpf" class="text-danger"></span>
					</div>
				</div>
				<div class="col-12 col-md-5 col-lg-4">
					<div class="form-group">
						<label asp-for="Pessoa.Nome" class="control-label">Nome Completo</label>
						<input asp-for="Pessoa.Nome" class="form-control" id="nomeInput" />
						<span asp-validation-for="Pessoa.Nome" class="text-danger"></span>
					</div>
				</div>
				<div class="col-12 col-md-4 col-lg-3">
					<div class="form-group">
						<label asp-for="Pessoa.Email" class="control-label">E-mail</label>
						<input asp-for="Pessoa.Email" class="form-control" id="emailInput" />
						<span asp-validation-for="Pessoa.Email" class="text-danger"></span>
					</div>
				</div>
			</div>
			<br />
			<div class="form-group">
				<button type="submit" class="btn btn-blue-normal text-white">Cadastrar Colaborador</button>
				<a asp-action="GerenciarEvento" asp-route-idEvento="@Model.Evento.Id" class="btn btn-outline-blue-normal text-dark close-modal">Voltar</a>
			</div>
		</form>
	</div>
</div>
<br />
<div class="row">
	<div class="table-responsive">
		<h4 class="blue-normal">Colaboradores já cadastrados</h4>
		<table class="table table-striped" id="myTable">
			<thead>
				<tr>
					<th>Nome</th>
					<th>CPF</th>
					<th>Ações</th>
				</tr>
			</thead>
			<tbody>
				@if (Model.Inscricoes != null)
				{
					@foreach (var item in Model.Inscricoes)
					{
						<tr>
							<td>@item.IdPessoaNavigation.Nome</td>
							<td>@FormatarCPF(item.IdPessoaNavigation.Cpf)</td>
							<td>
								<form id="removeForm-@item.IdPessoa" asp-action="DeletePessoaPapel" method="post">
									@Html.AntiForgeryToken()
									<input type="hidden" name="idPessoa" value="@item.IdPessoa" />
									<input type="hidden" name="idEvento" value="@item.IdEvento" />
									<input type="hidden" name="idPapel" value="3" />
									<button type="button" class="btn btn-sm btn-danger text-white" data-bs-toggle="modal" data-bs-target="#confirmRemovalModal" onclick="setModalValues('@item.IdPessoaNavigation.Nome', '@Model.Evento.Nome', '@item.IdPessoa')">Remover papel</button>
								</form>
							</td>
						</tr>
					}
				}
			</tbody>
		</table>
	</div>
</div>

<div class="modal fade" id="confirmRemovalModal" tabindex="-1" aria-labelledby="confirmRemovalModalLabel" aria-hidden="true">
	<div class="modal-dialog">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="confirmRemovalModalLabel">Confirmar Remoção</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				Deseja realmente remover o papel de colaborador de <strong id="pessoaNome"></strong> do evento <strong><span id="eventoNome"></span></strong>?
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-outline-blue-normal" data-bs-dismiss="modal">Cancelar</button>
				<button type="button" class="btn btn-danger" id="confirmRemovalButton">Remover</button>
			</div>
		</div>
	</div>
</div>

<script>
	function setModalValues(pessoaNome, eventoNome, presidential) {
		document.getElementById('pessoaNome').textContent = pessoaNome;
		document.getElementById('eventoNome').textContent = eventoNome;

		var removeForm = document.getElementById('removeForm-' + presidential);
		document.getElementById('confirmRemovalButton').onclick = function () {
			removeForm.submit();
		};
	}
</script>

@functions {
	public static string FormatarCPF(string cpf)
	{
		if (string.IsNullOrEmpty(cpf) || cpf.Length != 11)
			return cpf;

		return Convert.ToUInt64(cpf).ToString(@"000\.000\.000\-00");
	}
}

@section Scripts {
	<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/lib/datatable/js/datatables.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>

	<script>
		$(document).ready(function () {
			$('#cpfInput').mask('000.000.000-00', { reverse: true });
			$('#myTable').DataTable();
		});

		function buscarPessoaPorCPF() {
			var cpf = $('#cpfInput').val().replace(/\D/g, '');
			if (cpf.length === 11) {
				$.ajax({
					url: '@Url.Action("BuscarPessoaPorCPF", "Pessoa")',
					type: 'GET',
					data: { cpf: cpf },
					success: function (data) {
						if (data) {
							$('#nomeInput').val(data.nome);
							$('#emailInput').val(data.email);
						}
					}
				});
			}
		}

		function validarFormulario() {
			var cpf = $('#cpfInput').val().replace(/\D/g, '');
			$('#cpfInput').val(cpf);
			return true;
		}
	</script>
}