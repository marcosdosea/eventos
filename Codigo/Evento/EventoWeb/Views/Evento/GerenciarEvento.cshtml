@using Core
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model GerenciarEventoModel

@{
    ViewData["Title"] = "Gerenciar Evento";
    ViewData["ExibirMenuSanduiche"] = true;
}
<link rel="stylesheet" type="text/css" href="~/css/_gerenciarevento.css">

@if (TempData["Message"] != null)
{
    <div class="alert alert-danger" role="alert" id="alerterror">
        @TempData["Message"]
    </div>
    TempData.Remove("Message");
}
<script>
    setTimeout(function() {
        $("#alerterror").fadeOut("slow");
    }, 3000);</script>
    <div class="container mt-4">
        <div class="w-100 mb-4">
            <h1 class="blue-normal">Gerenciar evento</h1>
            <p>Nome:@Model.Evento.Nome Data:@Model.Evento.DataInicio</p>
        </div>

        <div class="row g-3 mb-5">
            @{
                var cards = new[] {
            new { Nome = "Inscrições", Action = "Index", Controller = "Participacaopessoaevento", Icon = "Inscricoes.png" },
            new { Nome = "Colaboradores", Action = "CreateColaborador", Controller = "Evento", Icon = "Colaboradores.png" },
            new { Nome = "Evento", Action = "GestorEditarEvento", Controller = "Evento", Icon = "Evento.png" },
            new { Nome = "Usuário", Action = "CreateParticipante", Controller = "Evento", Icon = "Participantes.png" }
        };
            }

            @foreach (var item in cards)
            {
                <div class="col-md-3">
                    <div class="card h-100 p-3 d-flex flex-column align-items-center justify-content-center text-center" style="min-height: 150px;">
                        <img src="~/ícones/@item.Icon" style="width: 50px; height: 50px; object-fit: contain;" alt="@item.Nome">
                        <div class="mt-3">
                            @Html.ActionLink(item.Nome, item.Action, item.Controller,
                                new { idEvento = Model.Evento.Id },
                                new { @class = "stretched-link text-decoration-none" })
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="mb-4">
        <button type="button" class="btn btn-blue-normal btn-lg" onclick="window.location.href='@Url.Action("CreateOrEdit", "Subevento", new { idEvento = Model.Evento.Id })'">
            Novo Subevento
        </button>
    </div>

    <div class="row mt-4 mb-2">
        <table class="table table-striped table-hover align-middle">
            <thead class="blue-normal blue-normal-bg-table">
                <tr>
                    <th>Tipo</th>
                    <th>Nome</th>
                    <th>Vagas Ofertadas</th>
                    <th>Vagas Disponíveis</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var subevento in Model.Subeventos)
                {
                    <tr>
                        <td>@subevento.NomeTipoEvento</td>
                        <td>@subevento.Nome</td>
                        <td>@subevento.VagasOfertadas</td>
                        <td>@subevento.VagasDisponiveis</td>
                        <td>
                            <div class="d-flex gap-3">
                                @Html.ActionLink("Editar", "CreateOrEdit", "Subevento",
                                    new { idEvento = Model.Evento.Id, idSubevento = subevento.Id },
                                    new { @style = "text-decoration:none;" })

                                @using (Html.BeginForm("Delete", "Subevento", FormMethod.Post, new { @style = "display:inline;" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@subevento.Id" />
                                    <a href="#" onclick="if (confirm('Tem certeza que deseja excluir?')) { this.closest('form').submit(); } return false;"
                                       style="color: #dc3545; text-decoration: none; cursor: pointer;">Excluir</a>
                                }

                                @Html.ActionLink("Tipo Inscrição", "CreateTipoInscricaoSubevento", "TipoInscricao",
                                    new { idEvento = Model.Evento.Id, idSubevento = subevento.Id },
                                    new { @style = "text-decoration:none;" })
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-end mt-2 mb-5 w-100">
            <a asp-controller="Evento" asp-action="GerenciarEventoListar" asp-route-idEvento="@ViewData["EventoId"]" class="btn btn-blue-normal btn-lg" style="text-decoration:none; color:white">
                Voltar
            </a>
        </div>
    </div>